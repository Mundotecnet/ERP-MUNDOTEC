# Copia este archivo a .env en cada entorno (prod y dev) y completa los valores.
# NUNCA subas el .env real al repositorio.

# --- Entorno ---
NODE_ENV=development # production | development
LOG_LEVEL=info # error | warn | info | debug | trace
HACIENDA_ENV=stag # stag (pruebas) | prod

# --- API (backend NestJS) ---
API_PORT=3000

# --- Base de datos PostgreSQL ---
POSTGRES_DB=mundotec_erp
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=cambia_esto_por_una_clave_fuerte
# Puerto en el host para docker-compose.dev.yml. NO usar 5432: ya lo ocupa el
# PostgreSQL de producción de este host (mundotec-web, mundotec-networking).
POSTGRES_HOST_PORT=5433

# URL de conexión que consume el api.
# Local (api en el host contra docker-compose.dev.yml): @localhost:${POSTGRES_HOST_PORT}
# Docker (api en el stack docker-compose.yml):           @db:5432  (red interna)
DATABASE_URL=postgres://erp_app:cambia_esto_por_una_clave_fuerte@localhost:5433/mundotec_erp

# --- Seguridad / tokens ---
JWT_SECRET=genera_un_secreto_largo_aleatorio
JWT_REFRESH_SECRET=otro_secreto_largo_aleatorio
JWT_ACCESS_EXPIRES_IN=15m  # formato jsonwebtoken: 30s | 15m | 2h | 7d
JWT_REFRESH_EXPIRES_IN=7d

# --- Política de bloqueo por intentos fallidos (HU-2.1) ---
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MIN=15

# --- Recuperación de contraseña (HU-2.3) ---
# Vida útil del token enviado por correo (en minutos).
RESET_TOKEN_EXPIRES_IN_MIN=60
# Base de la URL del frontend a la que se concatena ?token=...
MAIL_RESET_URL_BASE=https://erp.midominio.com/reset-password

# --- Mailer ---
# Transporte: "json" loguea el correo en stdout (default, dev/test).
#             "smtp" envía vía SMTP_HOST/PORT/USER/PASS (prod).
MAIL_TRANSPORT=json
MAIL_FROM="MundoTec ERP <no-reply@mundoteconline.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Seed (PR-3 en adelante) ---
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=cambia_esto_antes_de_correr_seed

# --- Dominios ---
STORE_DOMAIN=tienda.midominio.com
ERP_DOMAIN=erp.midominio.com

# --- Integraciones (completar al certificar) ---
# Hacienda: credenciales del usuario de API y ruta de la llave .p12 (en gestor de secretos)
# BAC compraCLICK: credenciales del comercio
# Correo/WhatsApp: proveedor de notificaciones
