# Copia este archivo a .env en cada entorno (prod y dev) y completa los valores.
# NUNCA subas el .env real al repositorio.

# --- Entorno ---
NODE_ENV=development # production | development
LOG_LEVEL=info # error | warn | info | debug | trace
HACIENDA_ENV=stag # stag (pruebas) | prod

# --- API (backend NestJS) ---
API_PORT=3000

# --- Base de datos PostgreSQL ---
POSTGRES_DB=mundotec_erp
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=cambia_esto_por_una_clave_fuerte
# Puerto en el host para docker-compose.dev.yml (default 5432).
POSTGRES_HOST_PORT=5432

# URL de conexión que consume el api.
# Local (api en el host contra docker-compose.dev.yml): @localhost:${POSTGRES_HOST_PORT}
# Docker (api en el stack docker-compose.yml):           @db:5432  (red interna)
DATABASE_URL=postgres://erp_app:cambia_esto_por_una_clave_fuerte@localhost:5432/mundotec_erp

# --- Seguridad / tokens ---
JWT_SECRET=genera_un_secreto_largo_aleatorio
JWT_REFRESH_SECRET=otro_secreto_largo_aleatorio

# --- Seed (PR-3 en adelante) ---
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=cambia_esto_antes_de_correr_seed

# --- Dominios ---
STORE_DOMAIN=tienda.midominio.com
ERP_DOMAIN=erp.midominio.com

# --- Integraciones (completar al certificar) ---
# Hacienda: credenciales del usuario de API y ruta de la llave .p12 (en gestor de secretos)
# BAC compraCLICK: credenciales del comercio
# Correo/WhatsApp: proveedor de notificaciones
