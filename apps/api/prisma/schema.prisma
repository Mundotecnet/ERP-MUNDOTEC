// MundoTec ERP — modelo Prisma del núcleo + catálogos base (Sprint 1).
//
// IMPORTANTE: la fuente de verdad del modelo es /db/erp_schema.sql.
// Cualquier cambio aquí debe reflejarse allí y viceversa; el script
// `pnpm db:check-drift` valida que las tablas modeladas coincidan.
//
// Convenciones:
//   - snake_case en DB, camelCase en TS vía @map/@@map.
//   - BIGINT GENERATED ALWAYS AS IDENTITY → BigInt @id @default(autoincrement()).
//   - NUMERIC(p,s) → Decimal @db.Decimal(p, s).
//   - TIMESTAMPTZ → DateTime @db.Timestamptz; DATE → DateTime @db.Date.
//   - JSONB → Json @db.JsonB.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  // native = host de desarrollo / CI (Ubuntu OpenSSL 3.x).
  // debian-openssl-3.0.x = imagen Docker node:20-slim (Bookworm).
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. NÚCLEO Y SEGURIDAD
// ============================================================================

model Company {
  id           BigInt    @id @default(autoincrement())
  legalName    String    @map("legal_name") @db.VarChar(200)
  tradeName    String?   @map("trade_name") @db.VarChar(200)
  taxId        String    @unique @map("tax_id") @db.VarChar(50)
  currencyCode String    @default("USD") @map("currency_code") @db.Char(3)
  address      String?   @db.VarChar(300)
  phone        String?   @db.VarChar(50)
  email        String?   @db.VarChar(150)
  logoUrl      String?   @map("logo_url") @db.VarChar(300)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  branches          Branch[]
  warehouses        Warehouse[]
  users             AppUser[]
  roles             Role[]
  taxes             Tax[]
  departments       Department[]
  productCategories ProductCategory[]
  customerCategories CustomerCategory[]
  passwordPolicy    PasswordPolicy?
  params            CompanyParam[]
  products          Product[]
  stockMovements    StockMovement[]
  partners          Partner[]
  purchaseOrders    PurchaseOrder[]
  goodsReceipts     GoodsReceipt[]

  @@map("company")
}

model Branch {
  id        BigInt   @id @default(autoincrement())
  companyId BigInt   @map("company_id")
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(150)
  address   String?  @db.VarChar(300)
  phone     String?  @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  company        Company         @relation(fields: [companyId], references: [id])
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]

  @@unique([companyId, code])
  @@map("branch")
}

// HU-3.2 — almacenes pertenecen a una empresa y opcionalmente a una sucursal.
model Warehouse {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  branchId  BigInt? @map("branch_id")
  code      String  @db.VarChar(20)
  name      String  @db.VarChar(120)
  isActive  Boolean @default(true) @map("is_active")

  company        Company         @relation(fields: [companyId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  stocks         Stock[]
  stockMovements StockMovement[]
  goodsReceipts  GoodsReceipt[]

  @@unique([companyId, code])
  @@map("warehouse")
}

model AppUser {
  id                  BigInt    @id @default(autoincrement())
  companyId           BigInt    @map("company_id")
  username            String    @db.VarChar(80)
  email               String    @db.VarChar(150)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  fullName            String    @map("full_name") @db.VarChar(150)
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz
  // Extensión sección 20.1 del erp_schema.sql (vendedores y comisiones).
  isSalesperson       Boolean   @default(false) @map("is_salesperson")
  commissionPct       Decimal   @default(0) @map("commission_pct") @db.Decimal(7, 4)

  company             Company              @relation(fields: [companyId], references: [id])
  userRoles           UserRole[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  stockMovements      StockMovement[]
  purchaseOrders      PurchaseOrder[]
  goodsReceipts       GoodsReceipt[]

  @@unique([companyId, username])
  @@unique([companyId, email])
  @@map("app_user")
}

model Role {
  id          BigInt  @id @default(autoincrement())
  companyId   BigInt  @map("company_id")
  name        String  @db.VarChar(80)
  description String? @db.VarChar(250)

  company         Company          @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, name])
  @@map("role")
}

model Permission {
  id          BigInt  @id @default(autoincrement())
  code        String  @unique @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String? @db.VarChar(250)

  rolePermissions RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  entity    String   @db.VarChar(80)
  entityId  BigInt?  @map("entity_id")
  action    String   @db.VarChar(20) // INSERT | UPDATE | DELETE
  oldValues Json?    @map("old_values") @db.JsonB
  newValues Json?    @map("new_values") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser? @relation(fields: [userId], references: [id])

  @@index([entity, entityId], map: "idx_audit_entity")
  @@map("audit_log")
}

// HU-2.1 / HU-2.2 — refresh tokens stateful (revocables al hacer logout).
model RefreshToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  jti        String    @unique @db.VarChar(64)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_user")
  @@map("refresh_token")
}

// HU-2.4 — políticas de contraseña por empresa.
model PasswordPolicy {
  companyId      BigInt   @id @map("company_id")
  minLength      Int      @default(10) @map("min_length")
  requireUpper   Boolean  @default(true) @map("require_upper")
  requireLower   Boolean  @default(true) @map("require_lower")
  requireDigit   Boolean  @default(true) @map("require_digit")
  requireSpecial Boolean  @default(false) @map("require_special")
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("password_policy")
}

// HU-6.3 — parámetros generales por empresa (key/value JSONB).
model CompanyParam {
  companyId BigInt   @map("company_id")
  key       String   @db.VarChar(80)
  value     Json?    @db.JsonB
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, key])
  @@map("company_param")
}

// HU-2.3 — token de recuperación de contraseña.
model PasswordResetToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  jti        String    @unique @db.VarChar(64)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_reset_user")
  @@map("password_reset_token")
}

// ============================================================================
// 2. CATÁLOGOS COMPARTIDOS
// ============================================================================

model Currency {
  code   String  @id @db.Char(3)
  name   String  @db.VarChar(60)
  symbol String? @db.VarChar(6)

  exchangeRates ExchangeRate[]

  @@map("currency")
}

model ExchangeRate {
  id           BigInt   @id @default(autoincrement())
  currencyCode String   @map("currency_code") @db.Char(3)
  rateDate     DateTime @map("rate_date") @db.Date
  rate         Decimal  @db.Decimal(18, 6)

  currency Currency @relation(fields: [currencyCode], references: [code])

  @@unique([currencyCode, rateDate])
  @@map("exchange_rate")
}

model Tax {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  name      String  @db.VarChar(60)
  rate      Decimal @db.Decimal(7, 4)
  isActive  Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@map("tax")
}

model UnitOfMeasure {
  id   BigInt @id @default(autoincrement())
  code String @unique @db.VarChar(10)
  name String @db.VarChar(60)

  products Product[]

  @@map("unit_of_measure")
}

model ProductCategory {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  parentId  BigInt? @map("parent_id")
  name      String  @db.VarChar(120)
  isActive  Boolean @default(true) @map("is_active")

  company  Company           @relation(fields: [companyId], references: [id])
  parent   ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryHierarchy")
  products Product[]

  @@map("product_category")
}

model Product {
  id                BigInt    @id @default(autoincrement())
  companyId         BigInt    @map("company_id")
  sku               String    @db.VarChar(60)
  barcode           String?   @db.VarChar(60)
  name              String    @db.VarChar(200)
  description       String?
  categoryId        BigInt?   @map("category_id")
  uomId             BigInt    @map("uom_id")
  taxId             BigInt?   @map("tax_id")
  costPrice         Decimal   @default(0) @map("cost_price") @db.Decimal(18, 4)
  salePrice         Decimal   @default(0) @map("sale_price") @db.Decimal(18, 4)
  priceCurrency     String    @default("USD") @map("price_currency") @db.Char(3)
  isInventoried     Boolean   @default(true) @map("is_inventoried")
  trackingType      String    @default("NONE") @map("tracking_type") @db.VarChar(10)
  warrantyMonths    Int       @default(0) @map("warranty_months")
  minStock          Decimal   @default(0) @map("min_stock") @db.Decimal(18, 4)
  maxStock          Decimal   @default(0) @map("max_stock") @db.Decimal(18, 4)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  // Fiscal CR — código de bienes y servicios (FK a cabys.code en el canónico,
  // que aún no está modelado).
  cabysCode         String?   @map("cabys_code") @db.VarChar(13)
  // Publicación en la tienda web (sprint 13). Sin lógica todavía.
  webPublished      Boolean   @default(false) @map("web_published")
  webFeatured       Boolean   @default(false) @map("web_featured")
  webTitle          String?   @map("web_title") @db.VarChar(200)
  webDescription    String?   @map("web_description")
  webSlug           String?   @map("web_slug") @db.VarChar(150)
  webPriceListId    BigInt?   @map("web_price_list_id")
  // Logística (modelos no canonizados aún: partner).
  departmentId      BigInt?   @map("department_id")
  defaultSupplierId BigInt?   @map("default_supplier_id")

  company           Company             @relation(fields: [companyId], references: [id])
  category          ProductCategory?    @relation(fields: [categoryId], references: [id])
  uom               UnitOfMeasure       @relation(fields: [uomId], references: [id])
  tax               Tax?                @relation(fields: [taxId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  stocks            Stock[]
  stockMovements    StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines GoodsReceiptLine[]

  @@unique([companyId, sku])
  @@index([barcode])
  @@index([name])
  @@map("product")
}

// HU-7.2 — Snapshot de existencias por producto y almacén. Las escrituras
// llegan vía `StockMovement` (kardex) en una transacción que recalcula
// `quantity` + `avgCost` con costo promedio ponderado.
model Stock {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt   @map("product_id")
  warehouseId BigInt   @map("warehouse_id")
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  avgCost     Decimal  @default(0) @map("avg_cost") @db.Decimal(18, 4)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock")
}

// HU-8.1 — Kardex / fuente de verdad del inventario. Cada fila representa una
// entrada (+), salida (-) o ajuste. `balance_qty` es el saldo del par
// (product, warehouse) después de aplicar el movimiento.
model StockMovement {
  id           BigInt   @id @default(autoincrement())
  companyId    BigInt   @map("company_id")
  productId    BigInt   @map("product_id")
  warehouseId  BigInt   @map("warehouse_id")
  movementType String   @map("movement_type") @db.VarChar(20)
  sourceDoc    String?  @map("source_doc") @db.VarChar(30)
  sourceId     BigInt?  @map("source_id")
  quantity     Decimal  @db.Decimal(18, 4)
  unitCost     Decimal  @default(0) @map("unit_cost") @db.Decimal(18, 4)
  balanceQty   Decimal  @default(0) @map("balance_qty") @db.Decimal(18, 4)
  movementDate DateTime @default(now()) @map("movement_date") @db.Timestamptz
  createdBy    BigInt?  @map("created_by")
  notes        String?  @db.VarChar(250)

  company   Company   @relation(fields: [companyId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      AppUser?  @relation(fields: [createdBy], references: [id])

  @@index([productId, warehouseId, movementDate], map: "idx_movement_product")
  @@map("stock_movement")
}

model Department {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  name      String  @db.VarChar(80)
  isActive  Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@unique([companyId, name])
  @@map("department")
}

model CustomerCategory {
  id        BigInt @id @default(autoincrement())
  companyId BigInt @map("company_id")
  code      String @db.VarChar(5)
  name      String @db.VarChar(80)

  company  Company   @relation(fields: [companyId], references: [id])
  partners Partner[]

  @@unique([companyId, code])
  @@map("customer_category")
}

// HU-9.1 — Terceros: clientes, proveedores y ambos.
// `partner_type` controla en qué módulos aparece (CUSTOMER, SUPPLIER, BOTH).
// Soft-delete: el partner no se borra físicamente (`deleted_at`).
model Partner {
  id                 BigInt    @id @default(autoincrement())
  companyId          BigInt    @map("company_id")
  partnerType        String    @map("partner_type") @db.VarChar(10)
  code               String?   @db.VarChar(30)
  legalName          String    @map("legal_name") @db.VarChar(200)
  tradeName          String?   @map("trade_name") @db.VarChar(200)
  taxId              String?   @map("tax_id") @db.VarChar(50)
  email              String?   @db.VarChar(150)
  phone              String?   @db.VarChar(50)
  address            String?   @db.VarChar(300)
  currencyCode       String    @default("USD") @map("currency_code") @db.Char(3)
  creditLimit        Decimal   @default(0) @map("credit_limit") @db.Decimal(18, 4)
  creditDays         Int       @default(0) @map("credit_days")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz
  // Extensión sección de ventas/categorización (canónico l.1502). Asocia el
  // partner a una categoría de cliente para descuentos/segmentación.
  customerCategoryId BigInt?   @map("customer_category_id")

  company           Company           @relation(fields: [companyId], references: [id])
  contacts          PartnerContact[]
  customerCategory  CustomerCategory? @relation(fields: [customerCategoryId], references: [id])
  purchaseOrders    PurchaseOrder[]

  @@unique([companyId, code])
  @@index([legalName], map: "idx_partner_name")
  @@map("partner")
}

model PartnerContact {
  id        BigInt  @id @default(autoincrement())
  partnerId BigInt  @map("partner_id")
  name      String  @db.VarChar(150)
  position  String? @db.VarChar(100)
  email     String? @db.VarChar(150)
  phone     String? @db.VarChar(50)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_contact")
}

// HU-9.2 — Cabecera de orden de compra.
// Estados: DRAFT (editable) → APPROVED → RECEIVED (lo setea PR-25 al recibir
// la última línea pendiente) o CANCELLED. Los totales son calculados por el
// service (subtotal, tax_amount, total en moneda del documento; base_total
// en moneda base de la empresa).
model PurchaseOrder {
  id            BigInt   @id @default(autoincrement())
  companyId     BigInt   @map("company_id")
  branchId      BigInt?  @map("branch_id")
  supplierId    BigInt   @map("supplier_id")
  orderNumber   String   @map("order_number") @db.VarChar(30)
  orderDate     DateTime @default(now()) @map("order_date") @db.Date
  expectedDate  DateTime? @map("expected_date") @db.Date
  status        String   @default("DRAFT") @db.VarChar(20)
  currencyCode  String   @default("USD") @map("currency_code") @db.Char(3)
  exchangeRate  Decimal  @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  subtotal      Decimal  @default(0) @db.Decimal(18, 4)
  taxAmount     Decimal  @default(0) @map("tax_amount") @db.Decimal(18, 4)
  total         Decimal  @default(0) @db.Decimal(18, 4)
  baseTotal     Decimal  @default(0) @map("base_total") @db.Decimal(18, 4)
  notes         String?  @db.VarChar(300)
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  company       Company             @relation(fields: [companyId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  supplier      Partner             @relation(fields: [supplierId], references: [id])
  user          AppUser?            @relation(fields: [createdBy], references: [id])
  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]

  @@unique([companyId, orderNumber])
  @@map("purchase_order")
}

model PurchaseOrderLine {
  id              BigInt  @id @default(autoincrement())
  purchaseOrderId BigInt  @map("purchase_order_id")
  productId       BigInt  @map("product_id")
  quantity        Decimal @db.Decimal(18, 4)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(18, 4)
  unitCost        Decimal @map("unit_cost") @db.Decimal(18, 4)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(7, 4)
  lineTotal       Decimal @map("line_total") @db.Decimal(18, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_line")
}

// HU-9.3 — Recepción de mercancía. Una recepción **es** la confirmación: el
// POST inserta header + líneas, alimenta el kardex (StockMovement IN por línea)
// y avanza `received_qty` de las líneas de la OC asociada (si hay) en una
// sola transacción Prisma. Si todas las líneas de la OC quedan completas, la
// OC pasa a RECEIVED en la misma tx. No hay PATCH ni DELETE: las recepciones
// son inmutables tras la creación; las correcciones se hacen vía devoluciones.
model GoodsReceipt {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt   @map("company_id")
  purchaseOrderId BigInt?  @map("purchase_order_id")
  warehouseId     BigInt   @map("warehouse_id")
  receiptNumber   String   @map("receipt_number") @db.VarChar(30)
  receiptDate     DateTime @default(now()) @map("receipt_date") @db.Date
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  company       Company            @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  user          AppUser?           @relation(fields: [createdBy], references: [id])
  lines         GoodsReceiptLine[]

  @@unique([companyId, receiptNumber])
  @@map("goods_receipt")
}

model GoodsReceiptLine {
  id             BigInt  @id @default(autoincrement())
  goodsReceiptId BigInt  @map("goods_receipt_id")
  productId      BigInt  @map("product_id")
  quantity       Decimal @db.Decimal(18, 4)
  unitCost       Decimal @map("unit_cost") @db.Decimal(18, 4)

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("goods_receipt_line")
}
