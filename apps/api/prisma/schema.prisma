// MundoTec ERP — modelo Prisma del núcleo + catálogos base (Sprint 1).
//
// IMPORTANTE: la fuente de verdad del modelo es /db/erp_schema.sql.
// Cualquier cambio aquí debe reflejarse allí y viceversa; el script
// `pnpm db:check-drift` valida que las tablas modeladas coincidan.
//
// Convenciones:
//   - snake_case en DB, camelCase en TS vía @map/@@map.
//   - BIGINT GENERATED ALWAYS AS IDENTITY → BigInt @id @default(autoincrement()).
//   - NUMERIC(p,s) → Decimal @db.Decimal(p, s).
//   - TIMESTAMPTZ → DateTime @db.Timestamptz; DATE → DateTime @db.Date.
//   - JSONB → Json @db.JsonB.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  // native = host de desarrollo / CI (Ubuntu OpenSSL 3.x).
  // debian-openssl-3.0.x = imagen Docker node:20-slim (Bookworm).
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. NÚCLEO Y SEGURIDAD
// ============================================================================

model Company {
  id           BigInt    @id @default(autoincrement())
  legalName    String    @map("legal_name") @db.VarChar(200)
  tradeName    String?   @map("trade_name") @db.VarChar(200)
  taxId        String    @unique @map("tax_id") @db.VarChar(50)
  currencyCode String    @default("USD") @map("currency_code") @db.Char(3)
  address      String?   @db.VarChar(300)
  phone        String?   @db.VarChar(50)
  email        String?   @db.VarChar(150)
  logoUrl      String?   @map("logo_url") @db.VarChar(300)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  branches          Branch[]
  warehouses        Warehouse[]
  users             AppUser[]
  roles             Role[]
  taxes             Tax[]
  departments       Department[]
  productCategories ProductCategory[]
  customerCategories CustomerCategory[]
  passwordPolicy    PasswordPolicy?
  params            CompanyParam[]
  products          Product[]
  stockMovements    StockMovement[]
  partners          Partner[]
  purchaseOrders    PurchaseOrder[]
  goodsReceipts     GoodsReceipt[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]
  priceHistory      ProductPriceHistory[]
  priceLists        PriceList[]

  @@map("company")
}

model Branch {
  id        BigInt   @id @default(autoincrement())
  companyId BigInt   @map("company_id")
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(150)
  address   String?  @db.VarChar(300)
  phone     String?  @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  company        Company         @relation(fields: [companyId], references: [id])
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]

  @@unique([companyId, code])
  @@map("branch")
}

// HU-3.2 — almacenes pertenecen a una empresa y opcionalmente a una sucursal.
model Warehouse {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  branchId  BigInt? @map("branch_id")
  code      String  @db.VarChar(20)
  name      String  @db.VarChar(120)
  isActive  Boolean @default(true) @map("is_active")

  company        Company         @relation(fields: [companyId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  stocks         Stock[]
  stockMovements StockMovement[]
  goodsReceipts  GoodsReceipt[]

  @@unique([companyId, code])
  @@map("warehouse")
}

model AppUser {
  id                  BigInt    @id @default(autoincrement())
  companyId           BigInt    @map("company_id")
  username            String    @db.VarChar(80)
  email               String    @db.VarChar(150)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  fullName            String    @map("full_name") @db.VarChar(150)
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz
  // Extensión sección 20.1 del erp_schema.sql (vendedores y comisiones).
  isSalesperson       Boolean   @default(false) @map("is_salesperson")
  commissionPct       Decimal   @default(0) @map("commission_pct") @db.Decimal(7, 4)

  company             Company              @relation(fields: [companyId], references: [id])
  userRoles           UserRole[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  stockMovements      StockMovement[]
  purchaseOrders      PurchaseOrder[]
  goodsReceipts       GoodsReceipt[]
  quotationsCreated   Quotation[]          @relation("QuotationCreatedBy")
  quotationsAsSeller  Quotation[]          @relation("QuotationSalesperson")
  salesOrdersCreated  SalesOrder[]         @relation("SalesOrderCreatedBy")
  salesOrdersAsSeller SalesOrder[]         @relation("SalesOrderSalesperson")
  invoicesCreated     Invoice[]            @relation("InvoiceCreatedBy")
  invoicesAsSeller    Invoice[]            @relation("InvoiceSalesperson")
  priceHistoryChanges ProductPriceHistory[]

  @@unique([companyId, username])
  @@unique([companyId, email])
  @@map("app_user")
}

model Role {
  id          BigInt  @id @default(autoincrement())
  companyId   BigInt  @map("company_id")
  name        String  @db.VarChar(80)
  description String? @db.VarChar(250)

  company         Company          @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, name])
  @@map("role")
}

model Permission {
  id          BigInt  @id @default(autoincrement())
  code        String  @unique @db.VarChar(100)
  module      String  @db.VarChar(50)
  description String? @db.VarChar(250)

  rolePermissions RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  entity    String   @db.VarChar(80)
  entityId  BigInt?  @map("entity_id")
  action    String   @db.VarChar(20) // INSERT | UPDATE | DELETE
  oldValues Json?    @map("old_values") @db.JsonB
  newValues Json?    @map("new_values") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser? @relation(fields: [userId], references: [id])

  @@index([entity, entityId], map: "idx_audit_entity")
  @@map("audit_log")
}

// HU-2.1 / HU-2.2 — refresh tokens stateful (revocables al hacer logout).
model RefreshToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  jti        String    @unique @db.VarChar(64)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_user")
  @@map("refresh_token")
}

// HU-2.4 — políticas de contraseña por empresa.
model PasswordPolicy {
  companyId      BigInt   @id @map("company_id")
  minLength      Int      @default(10) @map("min_length")
  requireUpper   Boolean  @default(true) @map("require_upper")
  requireLower   Boolean  @default(true) @map("require_lower")
  requireDigit   Boolean  @default(true) @map("require_digit")
  requireSpecial Boolean  @default(false) @map("require_special")
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("password_policy")
}

// HU-6.3 — parámetros generales por empresa (key/value JSONB).
model CompanyParam {
  companyId BigInt   @map("company_id")
  key       String   @db.VarChar(80)
  value     Json?    @db.JsonB
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, key])
  @@map("company_param")
}

// HU-2.3 — token de recuperación de contraseña.
model PasswordResetToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  jti        String    @unique @db.VarChar(64)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_reset_user")
  @@map("password_reset_token")
}

// ============================================================================
// 2. CATÁLOGOS COMPARTIDOS
// ============================================================================

model Currency {
  code   String  @id @db.Char(3)
  name   String  @db.VarChar(60)
  symbol String? @db.VarChar(6)

  exchangeRates ExchangeRate[]
  priceLists    PriceList[]

  @@map("currency")
}

model ExchangeRate {
  id           BigInt   @id @default(autoincrement())
  currencyCode String   @map("currency_code") @db.Char(3)
  rateDate     DateTime @map("rate_date") @db.Date
  rate         Decimal  @db.Decimal(18, 6)

  currency Currency @relation(fields: [currencyCode], references: [code])

  @@unique([currencyCode, rateDate])
  @@map("exchange_rate")
}

model Tax {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  name      String  @db.VarChar(60)
  rate      Decimal @db.Decimal(7, 4)
  isActive  Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@map("tax")
}

model UnitOfMeasure {
  id   BigInt @id @default(autoincrement())
  code String @unique @db.VarChar(10)
  name String @db.VarChar(60)

  products Product[]

  @@map("unit_of_measure")
}

model ProductCategory {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  parentId  BigInt? @map("parent_id")
  name      String  @db.VarChar(120)
  isActive  Boolean @default(true) @map("is_active")

  company  Company           @relation(fields: [companyId], references: [id])
  parent   ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryHierarchy")
  products Product[]

  @@map("product_category")
}

model Product {
  id                BigInt    @id @default(autoincrement())
  companyId         BigInt    @map("company_id")
  sku               String    @db.VarChar(60)
  barcode           String?   @db.VarChar(60)
  name              String    @db.VarChar(200)
  description       String?
  categoryId        BigInt?   @map("category_id")
  uomId             BigInt    @map("uom_id")
  taxId             BigInt?   @map("tax_id")
  costPrice         Decimal   @default(0) @map("cost_price") @db.Decimal(18, 4)
  salePrice         Decimal   @default(0) @map("sale_price") @db.Decimal(18, 4)
  // HU-11.1 — margen sobre el precio de venta (no sobre costo). CHECK 0 ≤ x < 1
  // se aplica vía SQL crudo en la migración (Prisma no modela CHECK).
  marginPct         Decimal   @default(0) @map("margin_pct") @db.Decimal(7, 4)
  minMarginPct      Decimal   @default(0) @map("min_margin_pct") @db.Decimal(7, 4)
  outOfMargin       Boolean   @default(false) @map("out_of_margin")
  priceCurrency     String    @default("USD") @map("price_currency") @db.Char(3)
  isInventoried     Boolean   @default(true) @map("is_inventoried")
  trackingType      String    @default("NONE") @map("tracking_type") @db.VarChar(10)
  warrantyMonths    Int       @default(0) @map("warranty_months")
  minStock          Decimal   @default(0) @map("min_stock") @db.Decimal(18, 4)
  maxStock          Decimal   @default(0) @map("max_stock") @db.Decimal(18, 4)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  // Fiscal CR — código de bienes y servicios (FK a cabys.code en el canónico,
  // que aún no está modelado).
  cabysCode         String?   @map("cabys_code") @db.VarChar(13)
  // Publicación en la tienda web (sprint 13). Sin lógica todavía.
  webPublished      Boolean   @default(false) @map("web_published")
  webFeatured       Boolean   @default(false) @map("web_featured")
  webTitle          String?   @map("web_title") @db.VarChar(200)
  webDescription    String?   @map("web_description")
  webSlug           String?   @map("web_slug") @db.VarChar(150)
  webPriceListId    BigInt?   @map("web_price_list_id")
  // Logística (modelos no canonizados aún: partner).
  departmentId      BigInt?   @map("department_id")
  defaultSupplierId BigInt?   @map("default_supplier_id")

  company           Company             @relation(fields: [companyId], references: [id])
  category          ProductCategory?    @relation(fields: [categoryId], references: [id])
  uom               UnitOfMeasure       @relation(fields: [uomId], references: [id])
  tax               Tax?                @relation(fields: [taxId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  stocks            Stock[]
  stockMovements    StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines GoodsReceiptLine[]
  quotationLines    QuotationLine[]
  salesOrderLines   SalesOrderLine[]
  invoiceLines      InvoiceLine[]
  priceHistory      ProductPriceHistory[]
  priceListItems    PriceListItem[]

  @@unique([companyId, sku])
  @@index([barcode])
  @@index([name])
  @@map("product")
}

// HU-11.1 — append-only. Cada cambio de costo/margen/precio inserta una row.
// `changeType` es 'COST' | 'SALE' (canónico). `source` ∈ 'MANUAL' | 'PURCHASE'
// | 'IMPORT_XML'. Las columnas extendidas (`costValue`, `marginPct`, `reason`)
// las introduce esta migración para guardar el snapshot trio + motivo.
model ProductPriceHistory {
  id          BigInt    @id @default(autoincrement())
  companyId   BigInt    @map("company_id")
  productId   BigInt    @map("product_id")
  changeType  String    @map("change_type") @db.VarChar(10)
  oldValue    Decimal?  @map("old_value") @db.Decimal(18, 4)
  newValue    Decimal   @map("new_value") @db.Decimal(18, 4)
  source      String?   @db.VarChar(15)
  sourceId    BigInt?   @map("source_id")
  changedBy   BigInt?   @map("changed_by")
  changedAt   DateTime  @default(now()) @map("changed_at") @db.Timestamptz
  costValue   Decimal?  @map("cost_value") @db.Decimal(18, 4)
  marginPct   Decimal?  @map("margin_pct") @db.Decimal(7, 4)
  reason      String?
  // PR-34: NULL para cambios que no pertenecen a un nivel (costo, min_margin).
  priceListId BigInt?   @map("price_list_id")

  product     Product   @relation(fields: [productId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])
  changedByUser AppUser? @relation(fields: [changedBy], references: [id])
  priceList   PriceList? @relation(fields: [priceListId], references: [id])

  @@index([productId, changedAt], map: "idx_pricehist_product")
  @@index([priceListId], map: "idx_pricehist_pricelist")
  @@map("product_price_history")
}

// HU-11.2 / PR-34 — Listas de precios. Por empresa, 3 listas seedeadas
// "Precio 1", "Precio 2", "Precio 3" (tipo SALE). Definido en canónico
// db/erp_schema.sql §8 (líneas 549–568) + extensión §22.
model PriceList {
  id           BigInt   @id @default(autoincrement())
  companyId    BigInt   @map("company_id")
  name         String   @db.VarChar(100)
  currencyCode String   @map("currency_code") @db.Char(3)
  listType     String   @default("SALE") @map("list_type") @db.VarChar(10)
  isActive     Boolean  @default(true) @map("is_active")

  company        Company               @relation(fields: [companyId], references: [id])
  currency       Currency              @relation(fields: [currencyCode], references: [code])
  items          PriceListItem[]
  priceHistory   ProductPriceHistory[]
  quotationLines QuotationLine[]

  @@unique([companyId, name])
  @@map("price_list")
}

model PriceListItem {
  id           BigInt   @id @default(autoincrement())
  priceListId  BigInt   @map("price_list_id")
  productId    BigInt   @map("product_id")
  price        Decimal  @db.Decimal(18, 4)
  minQuantity  Decimal  @default(1) @map("min_quantity") @db.Decimal(18, 4)
  validFrom    DateTime? @map("valid_from") @db.Date
  validTo      DateTime? @map("valid_to") @db.Date
  // PR-34 — margen objetivo capturado al fijar el precio (no se recalcula
  // automáticamente). CHECK 0 ≤ x < 1 aplicado en migración SQL.
  marginPct    Decimal  @default(0) @map("margin_pct") @db.Decimal(7, 4)
  outOfMargin  Boolean  @default(false) @map("out_of_margin")

  priceList    PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId, minQuantity])
  @@map("price_list_item")
}

// HU-7.2 — Snapshot de existencias por producto y almacén. Las escrituras
// llegan vía `StockMovement` (kardex) en una transacción que recalcula
// `quantity` + `avgCost` con costo promedio ponderado.
model Stock {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt   @map("product_id")
  warehouseId BigInt   @map("warehouse_id")
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  avgCost     Decimal  @default(0) @map("avg_cost") @db.Decimal(18, 4)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock")
}

// HU-8.1 — Kardex / fuente de verdad del inventario. Cada fila representa una
// entrada (+), salida (-) o ajuste. `balance_qty` es el saldo del par
// (product, warehouse) después de aplicar el movimiento.
model StockMovement {
  id           BigInt   @id @default(autoincrement())
  companyId    BigInt   @map("company_id")
  productId    BigInt   @map("product_id")
  warehouseId  BigInt   @map("warehouse_id")
  movementType String   @map("movement_type") @db.VarChar(20)
  sourceDoc    String?  @map("source_doc") @db.VarChar(30)
  sourceId     BigInt?  @map("source_id")
  quantity     Decimal  @db.Decimal(18, 4)
  unitCost     Decimal  @default(0) @map("unit_cost") @db.Decimal(18, 4)
  balanceQty   Decimal  @default(0) @map("balance_qty") @db.Decimal(18, 4)
  movementDate DateTime @default(now()) @map("movement_date") @db.Timestamptz
  createdBy    BigInt?  @map("created_by")
  notes        String?  @db.VarChar(250)

  company   Company   @relation(fields: [companyId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      AppUser?  @relation(fields: [createdBy], references: [id])

  @@index([productId, warehouseId, movementDate], map: "idx_movement_product")
  @@map("stock_movement")
}

model Department {
  id        BigInt  @id @default(autoincrement())
  companyId BigInt  @map("company_id")
  name      String  @db.VarChar(80)
  isActive  Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@unique([companyId, name])
  @@map("department")
}

model CustomerCategory {
  id        BigInt @id @default(autoincrement())
  companyId BigInt @map("company_id")
  code      String @db.VarChar(5)
  name      String @db.VarChar(80)

  company  Company   @relation(fields: [companyId], references: [id])
  partners Partner[]

  @@unique([companyId, code])
  @@map("customer_category")
}

// HU-9.1 — Terceros: clientes, proveedores y ambos.
// `partner_type` controla en qué módulos aparece (CUSTOMER, SUPPLIER, BOTH).
// Soft-delete: el partner no se borra físicamente (`deleted_at`).
model Partner {
  id                 BigInt    @id @default(autoincrement())
  companyId          BigInt    @map("company_id")
  partnerType        String    @map("partner_type") @db.VarChar(10)
  code               String?   @db.VarChar(30)
  legalName          String    @map("legal_name") @db.VarChar(200)
  tradeName          String?   @map("trade_name") @db.VarChar(200)
  taxId              String?   @map("tax_id") @db.VarChar(50)
  email              String?   @db.VarChar(150)
  phone              String?   @db.VarChar(50)
  address            String?   @db.VarChar(300)
  currencyCode       String    @default("USD") @map("currency_code") @db.Char(3)
  creditLimit        Decimal   @default(0) @map("credit_limit") @db.Decimal(18, 4)
  creditDays         Int       @default(0) @map("credit_days")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz
  // Extensión sección de ventas/categorización (canónico l.1502). Asocia el
  // partner a una categoría de cliente para descuentos/segmentación.
  customerCategoryId BigInt?   @map("customer_category_id")

  company           Company           @relation(fields: [companyId], references: [id])
  contacts          PartnerContact[]
  customerCategory  CustomerCategory? @relation(fields: [customerCategoryId], references: [id])
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]

  @@unique([companyId, code])
  @@index([legalName], map: "idx_partner_name")
  @@map("partner")
}

model PartnerContact {
  id        BigInt  @id @default(autoincrement())
  partnerId BigInt  @map("partner_id")
  name      String  @db.VarChar(150)
  position  String? @db.VarChar(100)
  email     String? @db.VarChar(150)
  phone     String? @db.VarChar(50)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_contact")
}

// HU-9.2 — Cabecera de orden de compra.
// Estados: DRAFT (editable) → APPROVED → RECEIVED (lo setea PR-25 al recibir
// la última línea pendiente) o CANCELLED. Los totales son calculados por el
// service (subtotal, tax_amount, total en moneda del documento; base_total
// en moneda base de la empresa).
model PurchaseOrder {
  id            BigInt   @id @default(autoincrement())
  companyId     BigInt   @map("company_id")
  branchId      BigInt?  @map("branch_id")
  supplierId    BigInt   @map("supplier_id")
  orderNumber   String   @map("order_number") @db.VarChar(30)
  orderDate     DateTime @default(now()) @map("order_date") @db.Date
  expectedDate  DateTime? @map("expected_date") @db.Date
  status        String   @default("DRAFT") @db.VarChar(20)
  currencyCode  String   @default("USD") @map("currency_code") @db.Char(3)
  exchangeRate  Decimal  @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  subtotal      Decimal  @default(0) @db.Decimal(18, 4)
  taxAmount     Decimal  @default(0) @map("tax_amount") @db.Decimal(18, 4)
  total         Decimal  @default(0) @db.Decimal(18, 4)
  baseTotal     Decimal  @default(0) @map("base_total") @db.Decimal(18, 4)
  notes         String?  @db.VarChar(300)
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  company       Company             @relation(fields: [companyId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  supplier      Partner             @relation(fields: [supplierId], references: [id])
  user          AppUser?            @relation(fields: [createdBy], references: [id])
  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]

  @@unique([companyId, orderNumber])
  @@map("purchase_order")
}

model PurchaseOrderLine {
  id              BigInt  @id @default(autoincrement())
  purchaseOrderId BigInt  @map("purchase_order_id")
  productId       BigInt  @map("product_id")
  quantity        Decimal @db.Decimal(18, 4)
  receivedQty     Decimal @default(0) @map("received_qty") @db.Decimal(18, 4)
  unitCost        Decimal @map("unit_cost") @db.Decimal(18, 4)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(7, 4)
  lineTotal       Decimal @map("line_total") @db.Decimal(18, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_line")
}

// HU-9.3 — Recepción de mercancía. Una recepción **es** la confirmación: el
// POST inserta header + líneas, alimenta el kardex (StockMovement IN por línea)
// y avanza `received_qty` de las líneas de la OC asociada (si hay) en una
// sola transacción Prisma. Si todas las líneas de la OC quedan completas, la
// OC pasa a RECEIVED en la misma tx. No hay PATCH ni DELETE: las recepciones
// son inmutables tras la creación; las correcciones se hacen vía devoluciones.
model GoodsReceipt {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt   @map("company_id")
  purchaseOrderId BigInt?  @map("purchase_order_id")
  warehouseId     BigInt   @map("warehouse_id")
  receiptNumber   String   @map("receipt_number") @db.VarChar(30)
  receiptDate     DateTime @default(now()) @map("receipt_date") @db.Date
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  company       Company            @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  user          AppUser?           @relation(fields: [createdBy], references: [id])
  lines         GoodsReceiptLine[]

  @@unique([companyId, receiptNumber])
  @@map("goods_receipt")
}

model GoodsReceiptLine {
  id             BigInt  @id @default(autoincrement())
  goodsReceiptId BigInt  @map("goods_receipt_id")
  productId      BigInt  @map("product_id")
  quantity       Decimal @db.Decimal(18, 4)
  unitCost       Decimal @map("unit_cost") @db.Decimal(18, 4)

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("goods_receipt_line")
}

// HU-10.1 — Cotizaciones (ventas).
// Estados: DRAFT (editable) → SENT → ACCEPTED → CONVERTED (lo setea PR-28 al
// crear la SalesOrder asociada) ; SENT/ACCEPTED → REJECTED ; DRAFT/SENT →
// EXPIRED. Cliente opcional (puede ser prospecto sin partner formal todavía).
// Totales calculados server-side; descuento por línea suportado.
// Columnas extra (cost_total, margin_*, global_adjust_*, sent_*, sales_stage)
// vienen del canónico secc. 18.1; en PR-27 sólo se modelan con defaults — la
// lógica de costo/margen llega con el sprint de Precios.
model Quotation {
  id                     BigInt    @id @default(autoincrement())
  companyId              BigInt    @map("company_id")
  branchId               BigInt?   @map("branch_id")
  customerId             BigInt?   @map("customer_id")
  opportunityId          BigInt?   @map("opportunity_id")
  quoteNumber            String    @map("quote_number") @db.VarChar(30)
  quoteDate              DateTime  @default(now()) @map("quote_date") @db.Date
  validUntil             DateTime? @map("valid_until") @db.Date
  status                 String    @default("DRAFT") @db.VarChar(15)
  currencyCode           String    @default("USD") @map("currency_code") @db.Char(3)
  exchangeRate           Decimal   @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  subtotal               Decimal   @default(0) @db.Decimal(18, 4)
  taxAmount              Decimal   @default(0) @map("tax_amount") @db.Decimal(18, 4)
  discountAmount         Decimal   @default(0) @map("discount_amount") @db.Decimal(18, 4)
  total                  Decimal   @default(0) @db.Decimal(18, 4)
  baseTotal              Decimal   @default(0) @map("base_total") @db.Decimal(18, 4)
  convertedSalesOrderId  BigInt?   @map("converted_sales_order_id")
  notes                  String?   @db.VarChar(300)
  createdBy              BigInt?   @map("created_by")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  // Extensión sección 18.1 — costos/márgenes/ajustes globales/envío por correo.
  // Sin lógica de negocio en este PR; el sprint de Precios los rellena.
  costTotal              Decimal   @default(0) @map("cost_total") @db.Decimal(18, 4)
  marginAmount           Decimal   @default(0) @map("margin_amount") @db.Decimal(18, 4)
  marginPct              Decimal   @default(0) @map("margin_pct") @db.Decimal(7, 4)
  globalAdjustType       String?   @map("global_adjust_type") @db.VarChar(12)
  globalAdjustValue      Decimal?  @map("global_adjust_value") @db.Decimal(18, 4)
  sentAt                 DateTime? @map("sent_at") @db.Timestamptz
  sentToEmail            String?   @map("sent_to_email") @db.VarChar(150)
  salesStage             String?   @map("sales_stage") @db.VarChar(20)
  // Extensión sección 20.1 — vendedor asignado a la cotización (para comisión).
  salespersonId          BigInt?   @map("salesperson_id")

  company     Company         @relation(fields: [companyId], references: [id])
  branch      Branch?         @relation(fields: [branchId], references: [id])
  customer    Partner?        @relation(fields: [customerId], references: [id])
  user        AppUser?        @relation("QuotationCreatedBy", fields: [createdBy], references: [id])
  salesperson AppUser?        @relation("QuotationSalesperson", fields: [salespersonId], references: [id])
  lines       QuotationLine[]
  salesOrders SalesOrder[]    @relation("SalesOrderFromQuotation")

  @@unique([companyId, quoteNumber])
  @@index([status], map: "idx_quotation_status")
  @@map("quotation")
}

model QuotationLine {
  id            BigInt   @id @default(autoincrement())
  quotationId   BigInt   @map("quotation_id")
  productId     BigInt?  @map("product_id")
  description   String?  @db.VarChar(250)
  quantity      Decimal  @db.Decimal(18, 4)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(18, 4)
  discountRate  Decimal  @default(0) @map("discount_rate") @db.Decimal(7, 4)
  taxRate       Decimal  @default(0) @map("tax_rate") @db.Decimal(7, 4)
  lineTotal     Decimal  @map("line_total") @db.Decimal(18, 4)
  // Extensión sección 18.1 — costo/margen por línea.
  unitCost      Decimal  @default(0) @map("unit_cost") @db.Decimal(18, 4)
  marginAmount  Decimal  @default(0) @map("margin_amount") @db.Decimal(18, 4)
  marginPct     Decimal  @default(0) @map("margin_pct") @db.Decimal(7, 4)
  // PR-37 — nivel de precio aplicado al cotizar (P1/P2/P3). NULL = línea
  // libre sin nivel asociado. El unit_price es editable por el vendedor.
  priceListId   BigInt?  @map("price_list_id")

  quotation Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  priceList PriceList? @relation(fields: [priceListId], references: [id])

  @@index([priceListId], map: "idx_quoteline_pricelist")
  @@map("quotation_line")
}

// HU-10.2 — Órdenes de venta.
// Estados: DRAFT (editable) → CONFIRMED → INVOICED (lo setea PR-29 al emitir
// la factura asociada) ; DRAFT/CONFIRMED → CANCELLED. Cliente REQUERIDO (a
// diferencia de cotización). Totales calculados server-side con descuento por
// línea. Puede originarse de una cotización (quotationId) — la conversión la
// hace `POST /quotations/:id/convert` en QuotationsService.
model SalesOrder {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt   @map("company_id")
  branchId        BigInt?  @map("branch_id")
  customerId      BigInt   @map("customer_id")
  opportunityId   BigInt?  @map("opportunity_id")
  quotationId     BigInt?  @map("quotation_id")
  orderNumber     String   @map("order_number") @db.VarChar(30)
  orderDate       DateTime @default(now()) @map("order_date") @db.Date
  status          String   @default("DRAFT") @db.VarChar(20)
  currencyCode    String   @default("USD") @map("currency_code") @db.Char(3)
  exchangeRate    Decimal  @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  subtotal        Decimal  @default(0) @db.Decimal(18, 4)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(18, 4)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(18, 4)
  total           Decimal  @default(0) @db.Decimal(18, 4)
  baseTotal       Decimal  @default(0) @map("base_total") @db.Decimal(18, 4)
  notes           String?  @db.VarChar(300)
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  // Extensión sección 20.1 — vendedor asignado (para comisión).
  salespersonId   BigInt?  @map("salesperson_id")
  // Extensión sección de canales (l. 1071-1075): origen del pedido y enlace
  // con la web. `channel` default 'POS' por el canónico; este sprint sólo lo
  // modela — la integración con el storefront es del sprint 13.
  channel         String   @default("POS") @db.VarChar(10)
  externalRef     String?  @map("external_ref") @db.VarChar(60)
  webStatus       String?  @map("web_status") @db.VarChar(15)

  company     Company          @relation(fields: [companyId], references: [id])
  branch      Branch?          @relation(fields: [branchId], references: [id])
  customer    Partner          @relation(fields: [customerId], references: [id])
  quotation   Quotation?       @relation("SalesOrderFromQuotation", fields: [quotationId], references: [id])
  user        AppUser?         @relation("SalesOrderCreatedBy", fields: [createdBy], references: [id])
  salesperson AppUser?         @relation("SalesOrderSalesperson", fields: [salespersonId], references: [id])
  lines       SalesOrderLine[]
  invoices    Invoice[]

  @@unique([companyId, orderNumber])
  @@map("sales_order")
}

model SalesOrderLine {
  id            BigInt  @id @default(autoincrement())
  salesOrderId  BigInt  @map("sales_order_id")
  productId     BigInt  @map("product_id")
  quantity      Decimal @db.Decimal(18, 4)
  unitPrice     Decimal @map("unit_price") @db.Decimal(18, 4)
  discountRate  Decimal @default(0) @map("discount_rate") @db.Decimal(7, 4)
  taxRate       Decimal @default(0) @map("tax_rate") @db.Decimal(7, 4)
  lineTotal     Decimal @map("line_total") @db.Decimal(18, 4)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("sales_order_line")
}

// HU-10.3 — Factura de venta.
// Estados: ISSUED (al crear) → CANCELLED. PARTIAL/PAID los maneja el sprint
// de Pagos. La factura es **inmutable** tras la emisión (sin PATCH, sin
// DELETE) — sólo se puede cancelar (status, sin revertir kardex; las
// devoluciones físicas van por sales_return en un sprint posterior).
// La emisión ejecuta atómicamente: header + líneas + StockMovement OUT por
// cada línea inventariada + transición SO→INVOICED si está asociada.
//
// Campos fiscales CR (document_type, ce_*, hacienda_*) se modelan con sus
// defaults canónicos pero su lógica vive en el microservicio fiscal (sprint
// 12). En este PR no se calculan ni se firman.
model Invoice {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt   @map("company_id")
  branchId        BigInt?  @map("branch_id")
  customerId      BigInt   @map("customer_id")
  salesOrderId    BigInt?  @map("sales_order_id")
  serviceOrderId  BigInt?  @map("service_order_id")
  invoiceNumber   String   @map("invoice_number") @db.VarChar(40)
  invoiceDate     DateTime @default(now()) @map("invoice_date") @db.Date
  dueDate         DateTime? @map("due_date") @db.Date
  status          String   @default("ISSUED") @db.VarChar(20)
  currencyCode    String   @default("USD") @map("currency_code") @db.Char(3)
  exchangeRate    Decimal  @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  subtotal        Decimal  @default(0) @db.Decimal(18, 4)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(18, 4)
  total           Decimal  @default(0) @db.Decimal(18, 4)
  baseTotal       Decimal  @default(0) @map("base_total") @db.Decimal(18, 4)
  paidAmount      Decimal  @default(0) @map("paid_amount") @db.Decimal(18, 4)
  balance         Decimal  @default(0) @db.Decimal(18, 4)
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  // Extensión sección 20.1 — vendedor (para comisiones).
  salespersonId   BigInt?  @map("salesperson_id")
  // Extensión fiscal CR (sección 11 del canónico). Sin lógica en este PR;
  // valores por defecto del canónico para que la columna no quede vacía.
  documentType    String   @default("FE") @map("document_type") @db.VarChar(3)
  ceClave         String?  @map("ce_clave") @db.Char(50)
  ceConsecutivo   String?  @map("ce_consecutivo") @db.Char(20)
  ceSecurityCode  String?  @map("ce_security_code") @db.Char(8)
  ceSituacion     Int      @default(1) @map("ce_situacion") @db.SmallInt
  emitterActivity String?  @map("emitter_activity") @db.VarChar(6)
  receiverActivity String? @map("receiver_activity") @db.VarChar(6)
  saleCondition   String   @default("01") @map("sale_condition") @db.VarChar(2)
  paymentMethod   String   @default("01") @map("payment_method") @db.VarChar(2)
  haciendaStatus  String   @default("PENDING") @map("hacienda_status") @db.VarChar(15)
  signedXmlUrl    String?  @map("signed_xml_url") @db.VarChar(400)
  responseXmlUrl  String?  @map("response_xml_url") @db.VarChar(400)
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz

  company     Company       @relation(fields: [companyId], references: [id])
  branch      Branch?       @relation(fields: [branchId], references: [id])
  customer    Partner       @relation(fields: [customerId], references: [id])
  salesOrder  SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  user        AppUser?      @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  salesperson AppUser?      @relation("InvoiceSalesperson", fields: [salespersonId], references: [id])
  lines       InvoiceLine[]

  @@unique([companyId, invoiceNumber])
  @@unique([ceClave], map: "uq_invoice_clave")
  @@index([haciendaStatus], map: "idx_invoice_hacienda_status")
  @@map("invoice")
}

model InvoiceLine {
  id             BigInt  @id @default(autoincrement())
  invoiceId      BigInt  @map("invoice_id")
  productId      BigInt? @map("product_id")
  description    String? @db.VarChar(250)
  quantity       Decimal @db.Decimal(18, 4)
  unitPrice      Decimal @map("unit_price") @db.Decimal(18, 4)
  taxRate        Decimal @default(0) @map("tax_rate") @db.Decimal(7, 4)
  lineTotal      Decimal @map("line_total") @db.Decimal(18, 4)
  // Extensión fiscal CR (sección 11).
  cabysCode      String? @map("cabys_code") @db.VarChar(13)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(18, 4)
  exemptAmount   Decimal @default(0) @map("exempt_amount") @db.Decimal(18, 4)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_line")
}
